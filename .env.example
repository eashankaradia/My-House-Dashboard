# Supabase — found in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used only by trusted server-side code (never exposed to the browser).
# Settings → API → service_role secret. Optional for the core app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The canonical site URL — used for OAuth redirects.
# Locally: http://localhost:3000  | Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
